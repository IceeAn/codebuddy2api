# 每行一个用户，格式为：
# 用户名:pbkdf2_sha256$迭代次数$salt$digest
#
# 下面的示例用户为 admin，示例密码为 change-me。公网部署前必须重新生成。
# 生成方式：
# python3 scripts/hash_password.py admin
# docker run --rm -it -v "$PWD/secrets:/app/secrets" ghcr.io/iceean/codebuddy2api:latest add-user admin
admin:pbkdf2_sha256$600000$eV2nlBG-_1R0S0zt_c1bhA$rcIcO86nNBdOcpvQ0gs7j0eIBZ7LjQsylsT9ViPSox0
