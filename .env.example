# ===============================================================
# CodeBuddy2API - 环境变量示例文件
#
# 如需覆盖默认配置，可将此文件复制为 .env 并删除对应配置行前的 # 后修改。
# ===============================================================

# -----------------
# 服务端配置
# -----------------

# 多用户认证文件路径。Docker 入口脚本会强制改用容器内私有运行时副本。
# CODEBUDDY_USERS_FILE=secrets/users.txt

# (可选) 服务监听的主机地址
# 默认值: 127.0.0.1
# CODEBUDDY_HOST=127.0.0.1

# (可选) 服务监听的端口
# 默认值: 8001
# CODEBUDDY_PORT=8001

# (公网部署必需) 允许访问本服务的 Host 头，多个值用逗号分隔。
# 例如: api.example.com,127.0.0.1,localhost
# CODEBUDDY_ALLOWED_HOSTS=localhost,127.0.0.1

# (可选) 允许跨域调用的前端 Origin，多个值用逗号分隔。
# 留空表示不启用跨域，只允许同源页面访问。
# CODEBUDDY_ALLOWED_ORIGINS=

# (安全边界) CSP 允许嵌入本页面的祖先来源；X-Frame-Options 始终为 DENY。
# 可设为 none，或使用空格分隔的 self 与 HTTP/HTTPS Origin，例如：self https://portal.example.com
# CODEBUDDY_CSP_FRAME_ANCESTORS=none

# (安全边界) 全局 HTTP 请求体上限，单位为字节；登录接口固定使用更小的 8 KiB 上限。
# CODEBUDDY_MAX_REQUEST_BODY_BYTES=16777216

# (安全边界) 登录限流窗口及三个独立速率桶，全部为正整数。
# CODEBUDDY_LOGIN_RATE_WINDOW_SECONDS=60
# CODEBUDDY_LOGIN_GLOBAL_MAX_ATTEMPTS=60
# CODEBUDDY_LOGIN_IP_MAX_ATTEMPTS=10
# CODEBUDDY_LOGIN_USERNAME_MAX_ATTEMPTS=5

# (安全边界) 同时进入工作线程或等待线程池的登录密码校验上限。
# CODEBUDDY_LOGIN_MAX_CONCURRENCY=2

# (可选) Uvicorn 全局连接/任务并发上限；默认留空表示不限制。
# CODEBUDDY_MAX_CONCURRENT_REQUESTS=

# (可信代理) 仅信任明确的反向代理 IP 或 CIDR，服务可不经反向代理访问时请勿设为 *。
# FORWARDED_ALLOW_IPS=127.0.0.1


# -----------------
# CodeBuddy API 配置
# -----------------

# (可选) CodeBuddy 官方 API 的端点地址
# 默认使用中国站；国际站可改为 https://www.codebuddy.ai
# CODEBUDDY_API_ENDPOINT=https://copilot.tencent.com

# (安全边界) 允许转发真实 CodeBuddy Token 的上游端点白名单。
# 默认允许中国站和国际站；必须全部为有效 HTTPS base URL，当前端点也必须明确列入，否则启动失败。
# CODEBUDDY_ALLOWED_API_ENDPOINTS=https://copilot.tencent.com,https://www.codebuddy.ai

# (可选) 本地运行时存放 SQLite 数据库和 CodeBuddy 凭证的目录
# 相对路径以应用根目录（config.py 所在目录）为基准。
# 默认值: data；Docker 容器固定使用 /app/data，忽略此项
# CODEBUDDY_DATA_DIR=data

# (安全边界) 是否校验上游 TLS 证书。公网部署必须保持 true。
# CODEBUDDY_SSL_VERIFY=true


# -----------------
# 高级配置
# -----------------

# (可选) 应用的日志级别
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
# 默认值: INFO
# CODEBUDDY_LOG_LEVEL=INFO

# (可选) 附加模型列表，用逗号分隔；系统会通过 CodeBuddy 动态获取全部可用模型，与此列表做并集。
# CODEBUDDY_MODELS=glm-5.2,deepseek-v4-pro

# (可选) 将 provider/model 形式的模型名在转发上游前改为 model；留空或 false 表示不处理
# CODEBUDDY_STRIP_MODEL_NAMESPACE=true
