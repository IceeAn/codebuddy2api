# ===============================================================
# CodeBuddy2API - 环境变量示例文件
#
# 使用前，请将此文件复制为 .env 并填写必要的值
# ===============================================================

# -----------------
# 服务端配置
# -----------------

# 多用户认证文件路径。Docker 部署默认挂载 ./secrets/users.txt 到此路径。
CODEBUDDY_USERS_FILE=secrets/users.txt

# (可选) 服务监听的主机地址
# 默认值: 127.0.0.1
CODEBUDDY_HOST=127.0.0.1

# (可选) 服务监听的端口
# 默认值: 8001
CODEBUDDY_PORT=8001

# (公网部署必需) 允许访问本服务的 Host 头，多个值用逗号分隔。
# 例如: api.example.com,127.0.0.1,localhost
CODEBUDDY_ALLOWED_HOSTS=localhost,127.0.0.1

# (可选) 允许跨域调用的前端 Origin，多个值用逗号分隔。
# 留空表示不启用跨域，只允许同源页面访问。
CODEBUDDY_ALLOWED_ORIGINS=


# -----------------
# CodeBuddy API 配置
# -----------------

# (可选) CodeBuddy 官方 API 的端点地址
# 默认使用中国站；国际站可改为 https://www.codebuddy.ai
CODEBUDDY_API_ENDPOINT=https://copilot.tencent.com

# (安全边界) 允许转发真实 CodeBuddy Token 的上游端点白名单。
# 默认允许中国站和国际站，避免 Token 被转发到非官方域名。
CODEBUDDY_ALLOWED_API_ENDPOINTS=https://copilot.tencent.com,https://www.codebuddy.ai

# (可选) 存放CodeBuddy认证凭证 (JSON文件) 的目录
# 默认值: .codebuddy_creds
CODEBUDDY_CREDS_DIR=.codebuddy_creds

# (可选) 本地运行时存放 SQLite 数据库的目录
# 默认值: data；Docker 容器固定使用 /app/data，忽略此项
CODEBUDDY_DATA_DIR=data

# (安全边界) 是否校验上游 TLS 证书。公网部署必须保持 true。
CODEBUDDY_SSL_VERIFY=true


# -----------------
# 高级配置
# -----------------

# (可选) 应用的日志级别
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
# 默认值: INFO
CODEBUDDY_LOG_LEVEL=INFO

# (可选) 附加模型列表，用逗号分隔；系统会通过 CodeBuddy 动态获取全部可用模型，与此列表做并集。
CODEBUDDY_MODELS=glm-5.2,deepseek-v4-pro

# (可选) 将 provider/model 形式的模型名在转发上游前改为 model；留空或 false 表示不处理
CODEBUDDY_STRIP_MODEL_NAMESPACE=true
