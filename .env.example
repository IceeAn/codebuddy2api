# ===============================================================
# CodeBuddy2API - 环境变量示例文件
#
# 使用前，请将此文件复制为 .env 并填写必要的值
# ===============================================================

# -----------------
# 服务端配置
# -----------------

# 多用户认证文件路径。Docker 部署默认挂载 ./secrets/users.txt 到此路径。
CODEBUDDY_USERS_FILE=secrets/users.txt

# (可选) 服务监听的主机地址
# 默认值: 127.0.0.1
CODEBUDDY_HOST=127.0.0.1

# (可选) 服务监听的端口
# 默认值: 8001
CODEBUDDY_PORT=8001

# (公网部署必需) 允许访问本服务的 Host 头，多个值用逗号分隔。
# 例如: api.example.com,127.0.0.1,localhost
CODEBUDDY_ALLOWED_HOSTS=localhost,127.0.0.1

# (可选) 允许跨域调用的前端 Origin，多个值用逗号分隔。
# 留空表示不启用跨域，只允许同源页面访问。
CODEBUDDY_ALLOWED_ORIGINS=


# -----------------
# CodeBuddy API 配置
# -----------------

# (可选) CodeBuddy官方API的端点地址
# 一般无需修改
CODEBUDDY_API_ENDPOINT=https://www.codebuddy.ai

# (安全边界) 允许转发真实 CodeBuddy Token 的上游端点白名单。
# 公网部署建议保持默认值，避免 Token 被转发到非官方域名。
CODEBUDDY_ALLOWED_API_ENDPOINTS=https://www.codebuddy.ai

# (可选) 存放CodeBuddy认证凭证 (JSON文件) 的目录
# 默认值: .codebuddy_creds
CODEBUDDY_CREDS_DIR=.codebuddy_creds

# (安全边界) 是否校验上游 TLS 证书。公网部署必须保持 true。
CODEBUDDY_SSL_VERIFY=true


# -----------------
# 高级配置
# -----------------

# (可选) 应用的日志级别
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
# 默认值: INFO
CODEBUDDY_LOG_LEVEL=INFO

# (可选) 向客户端报告可用的模型列表，用逗号分隔
# 用户可以根据自己的CodeBuddy账号支持的模型进行修改
CODEBUDDY_MODELS=claude-4.0,claude-3.7,gpt-5,gpt-5-mini,gpt-5-nano,o4-mini,gemini-2.5-flash,gemini-2.5-pro,auto-chat
